{
  "pack_id": "gdpr_pack_v2",
  "pack_name": "GDPR Policy Pack v2",
  "jurisdiction": "EU",
  "version": "2.0.0",
  "description": "GDPR-based policy pack for data placement and cross-border transfer assessment with quantitative compliance scoring and qualitative review hints.",
  "source": {
    "primary_document": "GDPR_번역문+(1).pdf",
    "included_articles": [5, 6, 9, 13, 14, 28, 30, 32, 44, 45, 46, 49],
    "notes": [
      "Core transfer rules: 28, 32, 44, 45, 46, 49",
      "Supporting quantitative rules: 5, 6, 9, 13, 14, 30"
    ]
  },
  "applies_when": {
    "all": [
      { "field": "data_subject_region", "in": ["EU", "EEA"] }
    ]
  },
  "result_schema": {
    "final_decision": "allow | deny | allow_with_conditions | manual_review",
    "risk_score": "0-100",
    "compliance_score": "0-100",
    "applied_pack": "string",
    "triggered_rules": "string[]",
    "legal_basis_articles": "number[]",
    "required_actions": "string[]",
    "recommended_regions": "string[]",
    "explanation": "string",
    "qualitative_review_hints": {
      "manual_review_required": "boolean",
      "review_boundary_summary": "string",
      "checklist": "string[]",
      "uncertainty_flags": "string[]"
    }
  },
  "decision_priority": {
    "order": ["deny", "manual_review", "allow_with_conditions", "allow"],
    "score_bands": {
      "low_risk": [0, 24],
      "moderate_risk": [25, 49],
      "high_risk": [50, 74],
      "critical_risk": [75, 100]
    }
  },
  "scoring_policy": {
    "base_risk_score": 20,
    "base_compliance_score": 50,
    "caps": {
      "min_risk_score": 0,
      "max_risk_score": 100,
      "min_compliance_score": 0,
      "max_compliance_score": 100
    }
  },
  "rules": [
    {
      "rule_id": "gdpr-art-5-purpose-limitation",
      "article": 5,
      "title": "Processing purpose must be defined",
      "category": "governance",
      "priority": 40,
      "decision": "allow_with_conditions",
      "risk_score_delta": 10,
      "compliance_score_delta": -10,
      "when": {
        "all": [
          { "field": "processing_purpose_defined", "eq": false }
        ]
      },
      "required_evidence": ["Documented processing purpose"],
      "required_actions": ["처리 목적을 명확히 정의하고 문서화"],
      "message": "처리 목적이 명확히 정의되지 않아 GDPR 제5조 원칙 충족이 불완전합니다.",
      "references": ["GDPR Article 5"]
    },
    {
      "rule_id": "gdpr-art-5-data-minimization",
      "article": 5,
      "title": "Data minimization check",
      "category": "governance",
      "priority": 40,
      "decision": "allow_with_conditions",
      "risk_score_delta": 8,
      "compliance_score_delta": -8,
      "when": {
        "all": [
          { "field": "data_minimized", "eq": false }
        ]
      },
      "required_evidence": ["Data minimization rationale"],
      "required_actions": ["수집 데이터 범위를 최소화하도록 재검토"],
      "message": "데이터 최소화 원칙 충족이 확인되지 않습니다.",
      "references": ["GDPR Article 5"]
    },
    {
      "rule_id": "gdpr-art-5-retention-defined",
      "article": 5,
      "title": "Retention period should be defined",
      "category": "governance",
      "priority": 35,
      "decision": "allow_with_conditions",
      "risk_score_delta": 6,
      "compliance_score_delta": -6,
      "when": {
        "all": [
          { "field": "retention_period_defined", "eq": false }
        ]
      },
      "required_evidence": ["Retention schedule"],
      "required_actions": ["보관기간 또는 삭제 정책 정의"],
      "message": "보관기간 제한 원칙을 위한 보관 정책이 정의되지 않았습니다.",
      "references": ["GDPR Article 5"]
    },
    {
      "rule_id": "gdpr-art-6-lawful-basis-missing",
      "article": 6,
      "title": "Lawful basis is required",
      "category": "lawfulness",
      "priority": 95,
      "decision": "deny",
      "risk_score_delta": 35,
      "compliance_score_delta": -35,
      "when": {
        "any": [
          { "field": "lawful_basis", "eq": null },
          { "field": "lawful_basis", "eq": "" }
        ]
      },
      "required_evidence": ["Selected lawful basis"],
      "required_actions": ["처리의 적법 근거를 지정"],
      "message": "처리의 적법 근거가 없어 GDPR 제6조 충족이 불가합니다.",
      "references": ["GDPR Article 6"]
    },
    {
      "rule_id": "gdpr-art-9-special-category-review",
      "article": 9,
      "title": "Special category data requires additional condition",
      "category": "sensitive_data",
      "priority": 90,
      "decision": "manual_review",
      "risk_score_delta": 20,
      "compliance_score_delta": -15,
      "when": {
        "all": [
          { "field": "contains_sensitive_data", "eq": true },
          { "field": "special_category_condition_met", "neq": true }
        ]
      },
      "required_evidence": ["Article 9 condition evidence"],
      "required_actions": ["민감정보 처리의 예외 근거 확인", "추가 내부 승인 검토"],
      "message": "민감정보가 포함되지만 제9조 예외 조건 충족이 확인되지 않아 수동 검토가 필요합니다.",
      "references": ["GDPR Article 9"]
    },
    {
      "rule_id": "gdpr-art-13-transfer-disclosure-missing",
      "article": 13,
      "title": "Transfer disclosure for directly collected data",
      "category": "transparency",
      "priority": 45,
      "decision": "allow_with_conditions",
      "risk_score_delta": 8,
      "compliance_score_delta": -10,
      "when": {
        "all": [
          { "field": "is_third_country_transfer", "eq": true },
          { "field": "transfer_disclosed_to_subject", "eq": false }
        ]
      },
      "required_evidence": ["Updated privacy notice", "Transfer disclosure notice"],
      "required_actions": ["정보주체에게 제3국 이전 관련 고지 반영"],
      "message": "제3국 이전 관련 정보주체 고지가 확인되지 않습니다.",
      "references": ["GDPR Article 13"]
    },
    {
      "rule_id": "gdpr-art-14-transfer-disclosure-missing",
      "article": 14,
      "title": "Transfer disclosure for indirectly collected data",
      "category": "transparency",
      "priority": 45,
      "decision": "allow_with_conditions",
      "risk_score_delta": 8,
      "compliance_score_delta": -10,
      "when": {
        "all": [
          { "field": "is_third_country_transfer", "eq": true },
          { "field": "privacy_notice_updated", "eq": false }
        ]
      },
      "required_evidence": ["Updated privacy notice"],
      "required_actions": ["제14조 기준 정보 제공 문구 반영"],
      "message": "고지 문서가 최신 이전 조건을 반영하지 않습니다.",
      "references": ["GDPR Article 14"]
    },
    {
      "rule_id": "gdpr-art-28-dpa-required",
      "article": 28,
      "title": "Processor requires DPA",
      "category": "processor",
      "priority": 92,
      "decision": "deny",
      "risk_score_delta": 30,
      "compliance_score_delta": -30,
      "when": {
        "all": [
          { "field": "uses_processor", "eq": true },
          { "field": "dpa_in_place", "eq": false }
        ]
      },
      "required_evidence": ["DPA or equivalent written agreement"],
      "required_actions": ["DPA 체결", "수탁처리 조건 문서화"],
      "message": "외부 처리자를 사용하지만 DPA가 없어 GDPR 제28조 요건을 충족하지 못합니다.",
      "references": ["GDPR Article 28"]
    },
    {
      "rule_id": "gdpr-art-28-processor-guarantees-review",
      "article": 28,
      "title": "Processor sufficient guarantees review",
      "category": "processor",
      "priority": 60,
      "decision": "manual_review",
      "risk_score_delta": 12,
      "compliance_score_delta": -10,
      "when": {
        "all": [
          { "field": "uses_processor", "eq": true },
          { "field": "dpa_in_place", "eq": true },
          { "field": "processor_sufficient_guarantees", "neq": true }
        ]
      },
      "required_evidence": ["Processor security/compliance evidence"],
      "required_actions": ["수탁처리자의 충분한 보증 입증자료 확인"],
      "message": "DPA는 존재하지만 수탁처리자의 충분한 보증 여부는 추가 검토가 필요합니다.",
      "references": ["GDPR Article 28"]
    },
    {
      "rule_id": "gdpr-art-30-ropa-missing",
      "article": 30,
      "title": "Records of processing activities should exist",
      "category": "documentation",
      "priority": 55,
      "decision": "allow_with_conditions",
      "risk_score_delta": 10,
      "compliance_score_delta": -12,
      "when": {
        "all": [
          { "field": "records_of_processing_exists", "eq": false }
        ]
      },
      "required_evidence": ["ROPA document"],
      "required_actions": ["처리 활동 기록부(ROPA) 작성"],
      "message": "처리 활동 기록부가 없어 제30조 문서화 수준이 부족합니다.",
      "references": ["GDPR Article 30"]
    },
    {
      "rule_id": "gdpr-art-30-transfer-doc-missing",
      "article": 30,
      "title": "Transfer and safeguards should be documented in ROPA",
      "category": "documentation",
      "priority": 58,
      "decision": "allow_with_conditions",
      "risk_score_delta": 10,
      "compliance_score_delta": -10,
      "when": {
        "all": [
          { "field": "is_third_country_transfer", "eq": true },
          { "field": "transfer_documented_in_ropa", "eq": false }
        ]
      },
      "required_evidence": ["ROPA entry for transfer and safeguards"],
      "required_actions": ["제3국 이전 및 안전조치 내용을 기록부에 반영"],
      "message": "제3국 이전 및 보호조치 문서화가 기록부에 반영되지 않았습니다.",
      "references": ["GDPR Article 30"]
    },
    {
      "rule_id": "gdpr-art-32-encryption-missing",
      "article": 32,
      "title": "Encryption controls missing",
      "category": "security",
      "priority": 85,
      "decision": "allow_with_conditions",
      "risk_score_delta": 18,
      "compliance_score_delta": -18,
      "when": {
        "any": [
          { "field": "encryption_at_rest", "eq": false },
          { "field": "encryption_in_transit", "eq": false }
        ]
      },
      "required_evidence": ["Encryption configuration", "Transport security evidence"],
      "required_actions": ["저장 시 암호화 적용", "전송 시 암호화 적용"],
      "message": "암호화 조치가 충분하지 않아 제32조 보안 기준 보완이 필요합니다.",
      "references": ["GDPR Article 32"]
    },
    {
      "rule_id": "gdpr-art-32-security-program-review",
      "article": 32,
      "title": "Access control and incident response review",
      "category": "security",
      "priority": 65,
      "decision": "manual_review",
      "risk_score_delta": 10,
      "compliance_score_delta": -8,
      "when": {
        "any": [
          { "field": "access_control_in_place", "eq": false },
          { "field": "incident_response_in_place", "eq": false }
        ]
      },
      "required_evidence": ["Access control policy", "Incident response procedure"],
      "required_actions": ["접근통제 정책 확인", "침해 대응 절차 확인"],
      "message": "기본 암호화 외 추가 보안 운영체계에 대한 검토가 필요합니다.",
      "references": ["GDPR Article 32"]
    },
    {
      "rule_id": "gdpr-art-44-third-country-transfer",
      "article": 44,
      "title": "Third-country transfer requires Chapter V basis",
      "category": "transfer_core",
      "priority": 88,
      "decision": "allow_with_conditions",
      "risk_score_delta": 15,
      "compliance_score_delta": -5,
      "when": {
        "all": [
          { "field": "is_third_country_transfer", "eq": true }
        ]
      },
      "required_evidence": ["Transfer mechanism evidence"],
      "required_actions": ["제45/46/49조 이전 근거 검토"],
      "message": "제3국 이전에 해당하므로 GDPR 제44조 검토가 필요합니다.",
      "references": ["GDPR Article 44"]
    },
    {
      "rule_id": "gdpr-art-45-adequacy-allow",
      "article": 45,
      "title": "Adequacy decision permits transfer",
      "category": "transfer_core",
      "priority": 91,
      "decision": "allow",
      "risk_score_delta": -15,
      "compliance_score_delta": 15,
      "when": {
        "all": [
          { "field": "is_third_country_transfer", "eq": true },
          { "field": "adequacy_decision_exists", "eq": true }
        ]
      },
      "required_evidence": ["Adequacy status metadata"],
      "required_actions": [],
      "message": "적정성 결정이 존재하므로 제45조에 따라 이전이 가능합니다.",
      "references": ["GDPR Article 45"]
    },
    {
      "rule_id": "gdpr-art-46-safeguards-conditional",
      "article": 46,
      "title": "Appropriate safeguards enable conditional transfer",
      "category": "transfer_core",
      "priority": 89,
      "decision": "allow_with_conditions",
      "risk_score_delta": 8,
      "compliance_score_delta": 8,
      "when": {
        "all": [
          { "field": "is_third_country_transfer", "eq": true },
          { "field": "adequacy_decision_exists", "eq": false },
          {
            "any": [
              { "field": "scc_in_place", "eq": true },
              { "field": "bcr_in_place", "eq": true },
              { "field": "other_safeguards_in_place", "eq": true }
            ]
          }
        ]
      },
      "required_evidence": ["SCC/BCR/other safeguard documents"],
      "required_actions": ["적절한 보호조치 문서 보관", "추가 보호조치 필요 여부 검토"],
      "message": "적정성 결정은 없지만 적절한 보호조치가 존재하여 제46조에 따라 조건부 이전이 가능합니다.",
      "references": ["GDPR Article 46"]
    },
    {
      "rule_id": "gdpr-art-49-derogation-manual-review",
      "article": 49,
      "title": "Derogation-based transfer requires manual review",
      "category": "transfer_exception",
      "priority": 93,
      "decision": "manual_review",
      "risk_score_delta": 22,
      "compliance_score_delta": -5,
      "when": {
        "all": [
          { "field": "is_third_country_transfer", "eq": true },
          { "field": "adequacy_decision_exists", "eq": false },
          { "field": "scc_in_place", "eq": false },
          { "field": "bcr_in_place", "eq": false },
          { "field": "derogation_used", "eq": true }
        ]
      },
      "required_evidence": ["Derogation rationale", "Necessity documentation"],
      "required_actions": ["예외 사유의 필요성 문서화", "반복적 이전 여부 검토", "관리자 승인"],
      "message": "예외 사유에 근거한 이전으로 제49조에 따라 수동 검토가 필요합니다.",
      "references": ["GDPR Article 49"]
    },
    {
      "rule_id": "gdpr-transfer-no-valid-mechanism",
      "article": 44,
      "title": "No valid transfer mechanism",
      "category": "transfer_core",
      "priority": 98,
      "decision": "deny",
      "risk_score_delta": 40,
      "compliance_score_delta": -40,
      "when": {
        "all": [
          { "field": "is_third_country_transfer", "eq": true },
          { "field": "adequacy_decision_exists", "eq": false },
          { "field": "scc_in_place", "eq": false },
          { "field": "bcr_in_place", "eq": false },
          { "field": "other_safeguards_in_place", "neq": true },
          { "field": "derogation_used", "eq": false }
        ]
      },
      "required_evidence": ["Valid transfer mechanism"],
      "required_actions": ["적정성 국가로 변경", "SCC/BCR 확보", "예외 사유 검토"],
      "message": "유효한 제3국 이전 근거가 없어 이전이 허용되기 어렵습니다.",
      "references": ["GDPR Articles 44-46"]
    }
  ],
  "qualitative_review_templates": {
    "boundary_summary": {
      "auto_decidable": "적정성 결정 존재 여부, SCC/BCR 존재 여부, DPA 존재 여부, 암호화 적용 여부, 기록부 존재 여부 등은 자동 판정 가능합니다.",
      "manual_review": "수탁처리자의 충분한 보증, 민감정보의 예외 조건 충족, derogation의 반복성·필요성, 추가 보안 운영체계의 실효성은 수동 검토가 필요합니다."
    },
    "checklist_templates": {
      "processor_review": [
        "수탁처리자 보안·인증 자료 확인",
        "계약상 역할과 책임 검토",
        "재위탁 여부 확인"
      ],
      "special_category_review": [
        "민감정보 처리 예외 근거 확인",
        "필요 최소 범위 여부 검토",
        "내부 승인 또는 법무 검토"
      ],
      "derogation_review": [
        "예외 사용의 necessity 문서화",
        "반복적/대량 이전 여부 확인",
        "대체 메커니즘 부재 사유 정리"
      ],
      "security_review": [
        "접근통제 정책 존재 여부",
        "침해사고 대응 계획",
        "추가 기술적 보호조치 검토"
      ]
    },
    "uncertainty_flags": {
      "processor_sufficient_guarantees": "수탁처리자의 충분한 보증은 정량화가 제한적입니다.",
      "special_category_condition_met": "민감정보 예외 조건은 해석 의존성이 있습니다.",
      "derogation_used": "제49조 예외는 보수적으로 검토해야 합니다.",
      "incident_response_in_place": "운영 절차의 실효성은 문서만으로 확정하기 어렵습니다."
    }
  }
}